// HELPERS
// ═══════════════════════════════════════════════════════════════════════════

/**
 * Insert an image item BEFORE a question, using a Drive File ID.
 * Inserta un image item ANTES de una pregunta, usando un Drive File ID.
 */
function insertImage(form, imageSlot, title) {
  const fileId = CONFIG.IMAGE_IDS[imageSlot];
  if (!fileId) {
    Logger.log('⚠ Missing image File ID for slot: ' + imageSlot + ' (skipping image insert)');
    return null;
  }
  const blob = DriveApp.getFileById(fileId).getBlob();
  const imageItem = form.addImageItem();
  imageItem.setImage(blob);
  if (title) imageItem.setTitle(title);
  return imageItem;
}

/**
 * Insert a YouTube video item BEFORE a question.
 * Inserta un video item de YouTube ANTES de una pregunta.
 */
function insertYoutubeVideo(form, youtubeUrl, title) {
  const videoItem = form.addVideoItem();
  videoItem.setVideoUrl(youtubeUrl);
  if (title) videoItem.setTitle(title);
  return videoItem;
}

/**
 * Insert a section header (no input, just title + description).
 * Useful for grouping or adding long explanatory text without a question.
 * Inserta un section header (sin input, solo título + descripción).
 * Útil para agrupar o agregar texto explicativo largo sin pregunta.
 */
function insertSection(form, title, description) {
  const item = form.addSectionHeaderItem();
  item.setTitle(title);
  if (description) item.setHelpText(description);
  return item;
}

/**
 * Insert a page break (creates a new section/page in the form).
 * Allows branching: respondent answers, then "go to section X based on answer".
 * Inserta un page break (crea nueva sección/página en el form).
 * Permite branching: respondent contesta, "ir a sección X según respuesta".
 */
function insertPageBreak(form, title, description) {
  const item = form.addPageBreakItem();
  item.setTitle(title);
  if (description) item.setHelpText(description);
  return item;
}
