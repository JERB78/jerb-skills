// ═══════════════════════════════════════════════════════════════════════════
// CONFIG / CONFIGURACIÓN
// ═══════════════════════════════════════════════════════════════════════════

const CONFIG = {
  // Form metadata / Metadata del form
  formTitle: '__FORM_TITLE__',
  formDescription: '__FORM_DESCRIPTION__',

  // Sheet metadata / Metadata de la sheet
  sheetName: '__SHEET_NAME__',

  // Custom headers (in column order, must match question order + 1 for timestamp)
  // Headers personalizados (en orden de columna, debe coincidir con orden de preguntas + 1 por timestamp)
  customHeaders: __SHEET_HEADERS_JSON__,
  // Example / Ejemplo:
  // ['timestamp', 'nombre', 'empresa', 'rol', 'años_experiencia', 'nps', 'comentarios']

  // Image File IDs (uploaded to Drive separately — paste IDs here)
  // File IDs de imágenes (subidas a Drive aparte — pegá IDs acá)
  IMAGE_IDS: __IMAGE_IDS_JSON__,
  // Example / Ejemplo:
  // { 'tabla_planes': 'ABC123xyz...', 'chart_nps_explicacion': 'DEF456abc...' }

  // L3 features / Features L3
  enableDashboard: __DASHBOARD_ENABLED__,    // true/false — adds Dashboard tab with live charts
  enableEmailNotify: __EMAIL_NOTIFY_ENABLED__, // true/false — sends email on every submit
  enableWebhook: __WEBHOOK_ENABLED__,         // true/false — POSTs to URL on every submit

  emailNotifyTo: '__EMAIL_NOTIFY_TO__',      // comma-separated emails, e.g. 'admin@x.com,manager@x.com'
  webhookUrl: '__WEBHOOK_URL__',             // full URL to POST to
};

// ═══════════════════════════════════════════════════════════════════════════
// MAIN ENTRY POINT / PUNTO DE ENTRADA PRINCIPAL
// ═══════════════════════════════════════════════════════════════════════════

function main() {
  Logger.log('=== Forms Builder Pro — starting ===');

  // Step 1: Create the form / Crear el form
  const form = createForm();
  Logger.log('✅ Form created: ' + form.getPublishedUrl());

  // Step 2: Create the Sheet and link it / Crear la Sheet y vincularla
  const spreadsheet = createAndLinkSheet(form);
  Logger.log('✅ Sheet created + linked: ' + spreadsheet.getUrl());

  // Step 3: Setup custom headers (must run AFTER linking but BEFORE first response)
  // Setup headers personalizados (después de vincular, antes de la primera respuesta)
  setupSheetHeaders(spreadsheet);
  Logger.log('✅ Custom headers configured');

  // Step 4: Setup Dashboard tab if enabled / Setup tab Dashboard si está habilitado
  if (CONFIG.enableDashboard) {
    setupDashboard(spreadsheet);
    Logger.log('✅ Dashboard tab created');
  }

  // Step 5: Install onFormSubmit triggers if enabled / Instalar triggers si están habilitados
  if (CONFIG.enableEmailNotify || CONFIG.enableWebhook) {
    installSubmitTriggers(form);
    Logger.log('✅ Submit triggers installed');
  }

  // Step 6: Final report / Reporte final
  Logger.log('');
  Logger.log('═══════════════════════════════════════════════');
  Logger.log('🎉 ALL DONE / TODO LISTO');
  Logger.log('═══════════════════════════════════════════════');
  Logger.log('Form URL (share this) / URL del Form (compartir): ' + form.getPublishedUrl());
  Logger.log('Form Edit URL (for tweaks) / URL de edición:       ' + form.getEditUrl());
  Logger.log('Sheet URL (responses + dashboard) / URL de Sheet:  ' + spreadsheet.getUrl());
}

// ═══════════════════════════════════════════════════════════════════════════
// STEP 1: CREATE FORM + ADD QUESTIONS
// ═══════════════════════════════════════════════════════════════════════════

function createForm() {
  const form = FormApp.create(CONFIG.formTitle);
  form.setDescription(CONFIG.formDescription);
  form.setShowLinkToRespondAgain(false);
  form.setCollectEmail(false); // change to true if you want respondent email
  form.setAllowResponseEdits(false);
  form.setAcceptingResponses(true);

  // ═══════════════════════════════════════════════════════════════════════
  // QUESTIONS BLOCK — auto-generated by the skill
  // BLOQUE DE PREGUNTAS — auto-generado por el skill
  //
  // The skill inserts the question snippets here, in order.
  // Each snippet handles image inserts, sections, helper text, etc.
  // See assets/question-types-snippets.gs for the available snippets.
  // ═══════════════════════════════════════════════════════════════════════

  __QUESTIONS_BLOCK__

  return form;
}

// ═══════════════════════════════════════════════════════════════════════════
// STEP 2: CREATE SHEET + LINK FORM
// ═══════════════════════════════════════════════════════════════════════════

function createAndLinkSheet(form) {
  // Create a new spreadsheet to hold responses
  // Crear una nueva spreadsheet para guardar respuestas
  const spreadsheet = SpreadsheetApp.create(CONFIG.sheetName);

  // Link form → spreadsheet (responses will auto-populate the first tab)
  // Vincular form → spreadsheet (respuestas se auto-pueblan en la primera tab)
  form.setDestination(FormApp.DestinationType.SPREADSHEET, spreadsheet.getId());

  return spreadsheet;
}

// ═══════════════════════════════════════════════════════════════════════════
// STEP 3: CUSTOM HEADERS (renaming + formatting)
// ═══════════════════════════════════════════════════════════════════════════

function setupSheetHeaders(spreadsheet) {
  // Wait for Google to create the linked tab (it's async after setDestination)
  // Esperar a que Google cree la tab linked (es async después de setDestination)
  Utilities.sleep(2000);

  // Re-fetch to get the latest sheet list (now includes the auto-created Form Responses tab)
  // Re-fetch para obtener la lista actual (ahora incluye la tab auto-creada Form Responses)
  const refreshedSS = SpreadsheetApp.openById(spreadsheet.getId());
  const sheets = refreshedSS.getSheets();

  // The form-linked sheet is the LAST one created (Google appends it)
  // La sheet linked al form es la ÚLTIMA creada (Google la appendea)
  const responseSheet = sheets[sheets.length - 1];
  responseSheet.setName('Respuestas');

  // Apply custom headers / Aplicar headers personalizados
  const headerRange = responseSheet.getRange(1, 1, 1, CONFIG.customHeaders.length);
  headerRange.setValues([CONFIG.customHeaders]);

  // Format header row / Formatear fila de header
  headerRange
    .setFontWeight('bold')
    .setBackground('#1e293b')   // slate-900
    .setFontColor('#ffffff')
    .setHorizontalAlignment('left')
    .setVerticalAlignment('middle');

  responseSheet.setFrozenRows(1);
  responseSheet.autoResizeColumns(1, CONFIG.customHeaders.length);

  // Set column widths to a sensible default (otherwise auto-resize is per-content)
  // Setear anchos de columna a un default razonable
  for (let i = 1; i <= CONFIG.customHeaders.length; i++) {
    responseSheet.setColumnWidth(i, 200);
  }
}

