// STEP 5: SUBMIT TRIGGERS (email + webhook)
// See assets/webhook-email-template.gs for the implementation.
// Ver assets/webhook-email-template.gs para la implementación.
// ═══════════════════════════════════════════════════════════════════════════

function installSubmitTriggers(form) {
  // Remove any existing triggers (avoid duplicates on re-run)
  // Remover triggers existentes (evitar duplicados en re-run)
  const allTriggers = ScriptApp.getProjectTriggers();
  for (const trigger of allTriggers) {
    if (trigger.getEventType() === ScriptApp.EventType.ON_FORM_SUBMIT) {
      ScriptApp.deleteTrigger(trigger);
    }
  }

  // Install new trigger / Instalar nuevo trigger
  ScriptApp.newTrigger('onFormSubmitHandler')
    .forForm(form)
    .onFormSubmit()
    .create();
}

// This function is called by the trigger on every form submission
// Esta función es llamada por el trigger en cada submission del form
function onFormSubmitHandler(e) {
  __SUBMIT_HANDLER_IMPLEMENTATION__
}

